# Conexion MAVSDK hacia PX4.
# Con AirSim + PX4 en WSL2, AirSim usa 14540 como puerto local de control.
# Canal MAVLink dedicado para el agente Python/MAVSDK:
# en PX4 ejecutar:
#   mavlink start -x -u 14600 -r 4000000 -t 172.25.48.1 -o 14601 -m onboard
PX4_SYSTEM_ADDRESS=udpin://0.0.0.0:14601
PX4_CONNECTION_TIMEOUT_SECONDS=5

# Conexion alternativa para diagnostico MAVLink directo con pymavlink.
# No ejecutar simultaneamente con MAVSDK sobre el mismo puerto.
PX4_MAVLINK_DIRECT_ADDRESS=udpin:0.0.0.0:14601

# Identificadores usados por el proyecto.
VEHICLE_NAME=Drone1
BOTTOM_CAMERA_NAME=bottom_center

# Parametros iniciales para pruebas seguras en simulacion.
PX4_TEST_ALTITUDE_M=3.0
PX4_TEST_HOVER_SECONDS=3.0
