# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
.venv_old_from_onedrive/
venv/
env/

# Local data and generated outputs
# Heavy experimental data are ignored, but README.md and .gitkeep files
# are versioned to preserve the reproducible project structure.

# data root
data/*
!data/
!data/README.md
!data/.gitkeep

# raw data
data/raw/*
!data/raw/
!data/raw/README.md
!data/raw/.gitkeep

# logs
data/logs/*
!data/logs/
!data/logs/README.md
!data/logs/.gitkeep

# Phase 05 curated lightweight summaries allowed for academic reproducibility
!data/logs/phase05_experiments/
data/logs/phase05_experiments/*
!data/logs/phase05_experiments/summary/
data/logs/phase05_experiments/summary/*
!data/logs/phase05_experiments/summary/phase05_run_summary.csv


# Public reproducibility curated data and manifests
!data/curated/
data/curated/*
!data/curated/phase05/
data/curated/phase05/*
!data/curated/phase05/phase05_run_summary.csv

!data/raw_manifest/
data/raw_manifest/*
!data/raw_manifest/raw_logs_inventory.csv
!data/raw_manifest/raw_logs_checksums.sha256
!data/raw_manifest/raw_logs_availability.md

!data/schema/
data/schema/*
!data/schema/phase05_run_summary_schema.md
!data/schema/phase05_metrics_dictionary.md
